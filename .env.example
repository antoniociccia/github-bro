# GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub Webhook Secret (optional, for webhook signature verification)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- LLM Provider ---
# Default: local worker (no config needed, just run with --profile local)
#
# To use OpenRouter (cloud) instead, set these:
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# OPENROUTER_MODEL=qwen/qwen3.5-35b-a3b
# LLM_BASE_URL=https://openrouter.ai/api/v1

# --- Local worker settings ---
# MODEL_REPO=Qwen/Qwen2.5-Coder-7B-Instruct-GGUF
# MODEL_FILE=qwen2.5-coder-7b-instruct-q4_k_m.gguf
# CONTEXT_SIZE=16384
# GPU_LAYERS=-1

# --- Authentication ---
# Shared secret for JWT signing and worker auth.
# If unset, a random secret is auto-generated and stored in the DB.
# Set explicitly when using the local worker (shared between containers).
# APP_SECRET=your-secret-here

# --- Polling ---
# POLL_REPOS=antoniociccia/github-bro
# POLL_INTERVAL=300

# Server port
PORT=3010
