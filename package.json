{
  "name": "github-bro",
  "version": "1.0.0",
  "description": "Your Git-Bro that spots you on every PR",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cd ui && npm run build",
    "build:server": "tsc",
    "build:ui": "cd ui && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "dry-run": "tsx src/dry-run.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "code-review",
    "ai",
    "github",
    "openrouter"
  ],
  "author": "antoniociccia",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "octokit": "^5.0.5",
    "openai": "^6.27.0",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
